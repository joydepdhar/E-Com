# Set DJANGO_ENV=production on Render or another hosted environment.
DJANGO_ENV=development
DEBUG=True

# Generate a unique value for every environment. Never commit a real key.
SECRET_KEY=replace-with-a-generated-django-secret-key

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Use your local database URL for development and your managed database URL in production.
# If you use Neon or another cloud database, include `sslmode=require` in the URL.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Cloudinary credentials are supplied by the environment.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional log-level controls. Keep INFO in production unless investigating.
DJANGO_LOG_LEVEL=INFO
STORE_LOG_LEVEL=INFO
PAYMENTS_LOG_LEVEL=INFO
ORDERS_LOG_LEVEL=INFO
AUTH_LOG_LEVEL=INFO
